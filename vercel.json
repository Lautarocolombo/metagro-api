{
  "version": 2,
  "builds": [
    {
      "src": "frontend/dist/**/*",
      "use": "@vercel/static",
      "config": { "maxAge": "1h" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://metagro-api-ds6r.onrender.com/api/$1" },
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/producto/([^/]+)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
