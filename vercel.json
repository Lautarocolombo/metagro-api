{
  "version": 2,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/products.json", "destination": "/products.json" },
    { "source": "/api/(.*)", "destination": "https://metagro-api-ds6r.onrender.com/api/$1" },
    { "source": "/:path+", "destination": "/index.html" }
  ]
}
