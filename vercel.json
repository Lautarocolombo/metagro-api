{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "framework": null,
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/styles/(.*)", "destination": "/styles/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
