# Servidor local (Express backend)
PORT=4000
NODE_ENV=development

# Base de datos PostgreSQL (Neon, Render o Vercel Postgres)
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Alternativa para scripts de backup
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Seguridad — JWT y tokens (REQUERIDO en producción)
JWT_SECRET=tu_jwt_secret_muy_aleatorio_aqui_32chars_minimo
METAGRO_TOKEN=tu_token_admin_generado_aleatoriamente

# Credenciales del panel admin
ADMIN_USER=metagro
ADMIN_PASS=tu_password_seguro_aqui

# Migración de imágenes (protege el endpoint /api/migrate-images)
MIGRATE_KEY=tu_clave_de_migracion_secreta_aleatoria

# Almacenamiento externo S3 / Cloudflare R2
S3_ACCESS_KEY_ID=tu_access_key
S3_SECRET_ACCESS_KEY=tu_secret_key
S3_BUCKET=metagro-productos
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
CDN_BASE_URL=https://cdn.metagro.com.ar

# WhatsApp Business API
WHATSAPP_TOKEN=tu_whatsapp_token
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_ADMIN=5403444466919

# Redis (cache + contador de visitas)
REDIS_URL=redis://localhost:6379

# Error tracking
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Backup automático
DB_BACKUP_ENABLED=false
