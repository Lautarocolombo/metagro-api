# Servidor local (Express backend)
PORT=4000
NODE_ENV=development

# Base de datos PostgreSQL (Neon, Render o Vercel Postgres)
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Seguridad — JWT y tokens (REQUERIDO en producción)
JWT_SECRET=tu_jwt_secret_muy_largo_y_aleatorio_aqui_32chars_minimo
MG_TOKEN=tu_token_admin_generado_aleatoriamente

# Credenciales del panel admin
ADMIN_USER=metagro
ADMIN_PASS=tu_password_seguro_aqui

# Migración de imágenes (protege el endpoint /api/migrate-images)
MIGRATE_KEY=tu_clave_de_migracion_secreta_aleatoria
